    {
      "name": "🔷 1. زمن المضارع التام (Present Perfect Tense)",
      "rule": "يُستخدم هذا الزمن للتحدث عن أحداث وقعت في الماضي ولكن وقت حدوثها غير محدد، أو أحداث لها ارتباط بالحاضر (نتيجة أو استمرارية).",
      "form": {
        "positive": "الفاعل + have/has + التصريف الثالث (past participle)",
        "negative": "الفاعل + haven't / hasn't + التصريف الثالث",
        "question": "Have/Has + الفاعل + التصريف الثالث؟"
      },
      "examples": {
        "positive": [
          "I have visited Paris. (لقد زرت باريس – لا نعرف متى بالضبط)",
          "She has finished her homework. (لقد أنهت واجبها – النتيجة: هي جاهزة الآن)"
        ],
        "negative": [
          "They haven't eaten yet. (لم يأكلوا بعد – ما زالوا جائعين الآن)",
          "He hasn't called me. (لم يتصل بي – ما زلت أنتظر)"
        ],
        "question": [
          "Have you ever been to London? (هل سبق أن زرت لندن؟)",
          "Has she seen that movie? (هل شاهدت ذلك الفيلم؟)"
        ]
      },
      "when_to_use": [
        "✅ تجربة أو حدث في الماضي دون ذكر وقت محدد (ever, never, before).",
        "✅ تغيير أو نتيجة حدثت مؤخراً ولها تأثير على الحاضر.",
        "✅ إنجازات شخصية أو إنسانية (بدون وقت محدد).",
        "✅ فترة زمنية لم تنتهِ بعد (today, this week, this month).",
        "✅ مع already, yet, just, since, for (سيأتي شرحها)."
      ],
      "common_mistakes": [
        "❌ خطأ: I have seen him yesterday. (لا نستخدم زمنين معاً)",
        "✅ صحيح: I saw him yesterday. (الماضي البسيط مع وقت محدد)",
        "❌ خطأ: She has went home.",
        "✅ صحيح: She has gone home. (التصريف الثالث من go هو gone)"
      ],
      "tips_for_weak_students": [
        "💡 تذكر: have مع (I, you, we, they) / has مع (he, she, it).",
        "💡 التصريف الثالث هو التصريف الذي يأتي بعد have/has. الأفعال المنتظمة نضيف لها ed، وغير المنتظمة تحفظ عن ظهر قلب.",
        "💡 إذا رأيت كلمات مثل: ever, never, already, yet, just, since, for، فهي إشارات قوية لاستخدام المضارع التام."
      ]
